# ==============================================================================
# .gitignore — generic multi-stack starter
# Delete the sections that don't apply to your project and add your own.
# ==============================================================================

# ── Environment variables and secrets ─────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Dependencies ──────────────────────────────────────────────────────────
node_modules/
vendor/
.venv/
venv/
__pycache__/

# ── Builds / artifacts ────────────────────────────────────────────────────
dist/
build/
out/
*.log
coverage/
.cache/
tmp/

# ── Operating system ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editors / IDE ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~
